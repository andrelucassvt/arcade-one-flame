<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android 12+ splash screen while the process starts. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/launcher_icon</item>
    </style>

    <!-- Theme applied as soon as the process has started. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
